15.PERFECT NUMBER
#include <stdio.h>
int main() {
    int n, i, sum = 0;
    scanf("%d", &n);
    for(i = 1; i < n; i++) {
        if(n % i == 0) {
            sum += i;
        }
    }
    if(sum == n)
        printf("Perfect Number");
    else
        printf("Not Perfect Number");
    return 0;
}

