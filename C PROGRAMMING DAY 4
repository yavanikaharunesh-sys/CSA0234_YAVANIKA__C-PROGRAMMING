6..AUTOMORPHIC NUMBER
#include <stdio.h>
int main() {
    int num, square, temp;
    scanf("%d", &num);
    square = num * num;
    temp = num;
    while (temp != 0) {
        if (temp % 10 != square % 10) {
            printf("Not Automorphic Number");
            return 0;
        }
        temp = temp / 10;
        square = square / 10;
    }
    printf("Automorphic Number");
    return 0;
}

7.MAGIC NUMBER
#include <stdio.h>
int main() {
    int num, sum = 0, remainder;
    scanf("%d", &num);
    while (num > 9) {
        sum = 0;
        while (num != 0) {
            remainder = num % 10;
            sum += remainder;
            num = num / 10;
        }
        num = sum;
    }
    if (num == 1)
        printf("Magic Number");
    else
        printf("Not Magic Number");
    return 0;
}

