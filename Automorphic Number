#include <stdio.h>
int main() {
    int n, sq, temp, count=0;
    scanf("%d",&n);
    sq = n*n;
    temp = n;

    while(temp!=0) {
        count++;
        temp/=10;
    }

    temp = n;
    while(count!=0) {
        if(temp%10 != sq%10) {
            printf("Not Automorphic");
            return 0;
        }
        temp/=10;
        sq/=10;
        count--;
    }
    printf("Automorphic");
}
