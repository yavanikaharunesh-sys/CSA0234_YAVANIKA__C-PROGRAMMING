#include <stdio.h>
int main() {
    int n, temp, sum=0, r, i, fact;
    scanf("%d",&n);
    temp = n;

    while(n!=0) {
        r = n%10;
        fact = 1;
        i = 1;
        while(i<=r) {
            fact *= i;
            i++;
        }
        sum += fact;
        n/=10;
    }

    if(temp==sum)
        printf("Strong");
    else
        printf("Not Strong");
}
